# =============================================================================
# Asset Persona Content Hub -- Environment Variables
# =============================================================================
# NEVER commit this file with real values to git.
# Copy to .env.local and fill in your values.
# For Supabase Edge Functions, use: supabase secrets set --env-file .env.local
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# Project URL from Settings > API in the Supabase dashboard.
SUPABASE_URL=

# Public anon key -- safe for browser clients. Security enforced via RLS.
SUPABASE_ANON_KEY=

# Service role key -- full database access. Used ONLY in Edge Functions and
# server-side code. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- n8n Automation ----------------------------------------------------------
# Base URL of your n8n instance (e.g., https://n8n.yourdomain.com or http://IP:5678).
N8N_URL=

# n8n API key for triggering workflows via webhook or REST.
N8N_API_KEY=

# --- Google AI (Gemini) ------------------------------------------------------
# API key from Google AI Studio. Used for content generation and AI features.
GOOGLE_AI_API_KEY=

# --- OpenAI ------------------------------------------------------------------
# API key from platform.openai.com. Used when GPT models are selected.
OPENAI_API_KEY=

# --- Anthropic ---------------------------------------------------------------
# API key from console.anthropic.com. Used when Claude models are selected.
ANTHROPIC_API_KEY=

# --- LinkedIn ----------------------------------------------------------------
# OAuth2 access token with w_member_social scope.
# If managed by n8n OAuth2 credential, export here for validation scripts.
LINKEDIN_ACCESS_TOKEN=

# Author URN for publishing (e.g., urn:li:person:XXXXX or urn:li:organization:XXXXX).
LINKEDIN_AUTHOR_URN=

# --- Meta Threads ------------------------------------------------------------
# Long-lived access token for the Threads API.
# Requires threads_basic + threads_content_publish permissions.
THREADS_ACCESS_TOKEN=

# Threads user ID (numeric). Found in Meta developer dashboard > Threads.
THREADS_USER_ID=

# --- Instagram ---------------------------------------------------------------
# Long-lived access token with instagram_content_publish scope.
# Requires a professional (Business or Creator) IG account linked to a Facebook Page.
INSTAGRAM_ACCESS_TOKEN=

# Instagram Business Account ID (numeric). Retrieved from the linked Facebook Page's
# instagram_business_account field via the Graph API.
INSTAGRAM_BUSINESS_ID=

# --- Facebook ----------------------------------------------------------------
# Page access token with pages_manage_posts permission.
FACEBOOK_PAGE_TOKEN=

# Facebook Page ID (numeric). Found in Page Settings > About.
FACEBOOK_PAGE_ID=

# --- Email (SMTP) ------------------------------------------------------------
# Used for sending notification emails (approval alerts, publish confirmations).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
