# ═══ Asset Persona — frontend env ═══

# Supabase (required)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Inquiry webhook Edge Function URL (defaults to <SUPABASE_URL>/functions/v1/inquiry-webhook)
# VITE_INQUIRY_WEBHOOK_URL=

# Plausible (optional — set both or neither)
# VITE_PLAUSIBLE_DOMAIN=www.assetpersona.com

# Dev bypass — see src/lib/devBypass.ts. Defaults DEV-only. Setting this in
# prod requires also setting VITE_ALLOW_DEV_BYPASS_IN_PROD=true.
# VITE_DEV_BYPASS=admin

# ═══ Edge Function secrets (NEVER prefix VITE_ — set via supabase secrets set) ═══
# Set these AFTER deploying the Edge Functions.
#
# In-app LLM (provider-agnostic adapter — supabase/functions/_shared/llm.ts)
#   Defaults: tutor → openrouter / google/gemma-4-26b-a4b-it
#             generator → openrouter / google/gemma-4-31b-it
#   Set ONE provider key minimum:
# OPENROUTER_API_KEY=sk-or-...
# DEEPSEEK_API_KEY=...
# GOOGLE_AI_API_KEY=...
# ANTHROPIC_API_KEY=...
# OPENAI_API_KEY=...
# Override per feature:
# LLM_TUTOR_PROVIDER=deepseek
# LLM_TUTOR_MODEL=deepseek-v4-flash
# LLM_GENERATOR_PROVIDER=openrouter
# LLM_GENERATOR_MODEL=google/gemma-4-31b-it
#
# n8n workflows (set per workflow you import)
# N8N_HMAC_SECRET=$(openssl rand -hex 32)
# N8N_WEBHOOK_URL=                       # inquiry-router workflow
# N8N_WELCOME_DRIP_URL=                  # welcome-drip workflow
# N8N_POST_COMPLETION_URL=               # post-completion-email workflow
# ALLOWED_ORIGIN=https://www.assetpersona.com,https://assetpersona.com
