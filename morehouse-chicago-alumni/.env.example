# ============================================================================
# Morehouse Chicago Alumni — environment template (mcaa-wave-001)
# Copy to `.env` (which is .gitignore'd) and fill in real values.
# NEVER commit a filled-in .env. Only this .example template is tracked.
#
# WHERE EACH SECRET LIVES (data-contract.md §9):
#   - The anon / publishable key is PUBLIC and belongs in js/config.js (committed,
#     safe — RLS protects every table). It is duplicated here only for tooling.
#   - PAYPAL_CLIENT_ID is BROWSER-SAFE: it ships in the PayPal JS SDK <script>
#     src on the payment pages. It may appear in client files.
#   - The privileged server key, PAYPAL_CLIENT_SECRET, and PAYPAL_WEBHOOK_ID are
#     SERVER-SIDE ONLY. They are set as Supabase Edge Function secrets via
#     `supabase secrets set ...` and are NEVER placed in any client file
#     (js/, *.html). A hard gate greps client files for those names and must
#     return zero.
# ============================================================================

# --- Public (browser-safe; mirrors js/config.js) ----------------------------
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-PUBLISHABLE-KEY

# --- Server-side ONLY: Edge Function env via `supabase secrets set` ----------
# Bypasses RLS. If this leaks, the entire database is exposed. Never client-side.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY-SERVER-ONLY

# --- PayPal (funds settle to the chapter's Chase Business account) -----------
# Client ID is BROWSER-SAFE: it is the `client-id` in the PayPal JS SDK script
# tag on the membership/donate/event pages. Safe to commit in js/config.js.
PAYPAL_CLIENT_ID=YOUR-PAYPAL-CLIENT-ID-BROWSER-SAFE
# Client secret: server-side ONLY (OAuth2 client-credentials for the Edge
# Functions). Pairs with the client id; never client-side.
PAYPAL_CLIENT_SECRET=YOUR-PAYPAL-CLIENT-SECRET-SERVER-ONLY
# Webhook id: from the PayPal Dashboard webhook. Required by paypal-webhook to
# call verify-webhook-signature. Server-side ONLY.
PAYPAL_WEBHOOK_ID=YOUR-PAYPAL-WEBHOOK-ID-SERVER-ONLY
# Environment selector for the Edge Functions: 'sandbox' (default) or 'live'.
# The board sets 'live' only in production. Browser SDK uses the matching client
# id automatically; no host is hardcoded.
PAYPAL_ENV=sandbox
